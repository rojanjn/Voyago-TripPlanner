@model IEnumerable<TripPlanner.Models.Itinerary>

@{
    ViewData["Title"]="Itineraries";
}

@section Scripts {
    <script>
        document.querySelector('.navbar').classList.add('scrolled');
    </script>
}

<div class="page-container">
    
    <div class="view-header">
        <h2 class="view-title">View</h2>
        <a asp-action="Create" class="add-itinerary">Add Itinerary</a>
    </div>

    <div class="tabs">
        <button class="tab active" onclick="showTab('current')">Current</button>
        <button class="tab" onclick="showTab('past')">Past</button>
    </div>

    <div class="main-grid">

        <!-- Left side: itineraries -->
        <div class="itinerary-section">

            <div id="current" class="tab-content active">
                <div class="itinerary-grid">
                    @foreach (var item in Model.Where(t => t.EndDate >= DateTime.Now))
                    {
                        <div class="itinerary-card" 
                             onclick="window.location='@Url.Action("Details", new { id = item.Id })'">

                            <div class="card-actions">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="card-btn edit-btn"
                                   onclick="event.stopPropagation();">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="card-btn delete-btn"
                                   onclick="event.stopPropagation();">
                                    Delete
                                </a>
                            </div>

                            <div class="card-header">
                                <span class="title">@item.Title</span>
                                <span class="country">@item.Country?.CountryName</span>
                            </div>

                            <div class="dates">
                                @item.StartDate.ToShortDateString() →
                                @item.EndDate.ToShortDateString()
                            </div>

                            <p class="note">
                                @item.Description
                            </p>
                        </div>
                    }
                </div>
            </div>

            <div id="past" class="tab-content">
                <div class="itinerary-grid">
                    @foreach (var item in Model.Where(t => t.EndDate < DateTime.Now))
                    {
                        <div class="itinerary-card" 
                             onclick="window.location='@Url.Action("Details", new { id = item.Id })'">

                            <div class="card-header">
                                <span class="title">@item.Title</span>
                                <span class="country">@item.Country?.CountryName</span>
                            </div>

                            <div class="dates">
                                @item.StartDate.ToShortDateString() →
                                @item.EndDate.ToShortDateString()
                            </div>

                            <p class="note">
                                @item.Description
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>