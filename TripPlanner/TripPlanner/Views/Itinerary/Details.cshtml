@using System.Text.Json
@using System.Linq
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model TripPlanner.Models.Itinerary

@{
    Layout = "_Layout";
}


<div class="details-page">
    <div class="details-container">

        <!-- LEFT: MAP PANEL -->
        <div class="map-panel">
            <div class="map-search-box">
                <input type="text"
                       id="attractionSearch"
                       placeholder="Search attractions..."
                       autocomplete="off"/>
                <div id="searchResults" class="search-dropdown"></div>
            </div>

            <div id="map" class="map-view" data-itinerary-id="@Model.Id"></div>


            <button id="add-location" class="btn-add-location" disabled>
                Add Location
            </button>
        </div>

        <!-- RIGHT: TRIP INFO PANEL -->
        <div class="info-panel">
            <div class="info-card">

                <!-- Trip Header -->
                <div class="info-header">
                    <h1 class="trip-title-detail">@Model.Title</h1>
                    <p class="trip-subtitle">@Model.Country?.CountryName</p>
                </div>

                <!-- Trip Description -->
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="trip-description-box">
                        <p>@Model.Description</p>
                    </div>
                }

                <!-- Time Display -->
                <div class="time-display">
                    <div class="time-label">Time</div>
                    <div class="time-value">
                        @Model.StartDate.ToString("MMM dd, yyyy")
                        →
                        @Model.EndDate.ToString("MMM dd, yyyy")
                    </div>
                </div>

                @if (Model.ItineraryItems != null && Model.ItineraryItems.Count >= 2)
                {
                    <div class="route-summary" id="routeSummary" style="display:none;">
                        <span class="route-summary-icon">🚗</span>
                        <span>Total: </span>
                        <strong id="totalDistance">—</strong>
                        <span>&nbsp;·&nbsp;</span>
                        <strong id="totalDuration">—</strong>
                    </div>
                }

                <!-- Locations List -->
                <div class="locations-section">
                    <h3 class="section-title">Location</h3>

                    @{
                        var orderedItems = Model.ItineraryItems?.OrderBy(i => i.StopOrder).ToList() ?? new List<TripPlanner.Models.ItineraryItem>();
                    }

                    @if (orderedItems.Any())
                    {
                        <div class="locations-list">
                            @for (int idx = 0; idx < orderedItems.Count; idx++)
                            {
                                var item = orderedItems[idx];
                                @await Html.PartialAsync("_LocationItem", item)

                                @* ← Leg connector inserted HERE, after card, before next iteration *@
                                @if (idx < orderedItems.Count - 1)
                                {
                                    <div class="leg-connector" data-leg-index="@idx">
                                        <div class="leg-line"></div>
                                        <div class="leg-info">
                                            <span class="leg-distance">—</span>
                                            <span class="leg-sep">·</span>
                                            <span class="leg-duration">—</span>
                                        </div>
                                        <div class="leg-line"></div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-state">No attractions added yet.</p>
                    }
                </div>

                <!-- Back Button -->
                <a asp-action="Index" class="btn-back-detail">Back to Trips</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/details-map.js"></script>
    <script src="~/js/details-locations.js"></script>

    <script>
        // Make navbar white immediately on Details page
        document.querySelector('.navbar').classList.add('scrolled');
        
        window.__itineraryId = @Model.Id;
        window.__locations = @Html.Raw(JsonSerializer.Serialize(
                                 Model.ItineraryItems?.Select(i => new
                                 {
                                     lat = i.Location.Latitude,
                                     lng = i.Location.Longitude,
                                     name = i.Location.Name
                                 }) ?? Enumerable.Empty<object>()
                             ));
    </script>

    <script
        src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleMaps:ApiKey"]&libraries=places,geometry&v=weekly&callback=initMap&language=en"
        async defer>
    </script>
}