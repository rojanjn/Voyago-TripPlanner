@using System.Text.Json
@using System.Linq
@model TripPlanner.Models.Itinerary

@{
    Layout = "_Layout";
}

<div class="details-page page-container">
    
    <div class="trip-layout">
    
        <!-- LEFT: MAP -->
        <div class="details-map-panel">
            <div class="attraction-search">
                <input type="text" id="attractionSearch" placeholder="Search attractions..." autocomplete="off" />
                @*<div id="searchResults" class="search-dropdown"></div>*@
            </div>
            
            <div id="map"></div>
            <button id="btnAddAttraction" class="btn-add-attraction">Add attraction</button>
        </div>
    
    
        <!-- RIGHT: TRIP DETAILS -->
        <div class="trip-panel">
    
            <div class="trip-header">
                <h2>@Model.Title</h2>
                
                <div class="trip-country">
                    @Model.Country?.CountryName
                </div>

                <div class="trip-description">
                    @Model.Description
                </div>
    
                <div class="trip-dates">
                    @Model.StartDate.ToShortDateString()
                    →
                    @Model.EndDate.ToShortDateString()
                </div>
            </div>
    
            <div class="attractions-list">
    
                @if (Model.ItineraryItems != null && Model.ItineraryItems.Any())
                {
                    int stopNumber = 1;
    
                    foreach (var item in Model.ItineraryItems.OrderBy(i => i.StopOrder))
                    {
                        <div class="attraction-card" data-item-id="@item.Id">
    
                            <div class="stop-number">
                                @stopNumber
                            </div>
    
                            @*<img src="@item.Location.ImageUrl"
                                 class="attraction-thumb"/>*@
    
                            <div class="attraction-info">
    
                                <div class="attraction-name">
                                    @item.Location.Name
                                </div>
    
                                <div class="attraction-address">
                                    @item.Location.Address
                                </div>
    
                                <div class="travel-info">
                                    @item.StartDateTime.ToString("t")
                                    →
                                    @item.EndDateTime.ToString("t")
                                </div>
                            </div>
    
                            <div class="attraction-actions">
                                <button class="btn-remove">✕</button>
                            </div>
                        </div>
                        stopNumber++;
                    }
                }
                else
                {
                    <p>No attractions added yet.</p>
                }
            </div>
    
            <a asp-action="Index" class="btn-back">Back</a>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        document.querySelector('.navbar').classList.add('scrolled');
    </script>
    
    <script>
        function initMap() {
            const map = new google.maps.Map(document.getElementById("map"), {
                zoom: 10,
                center: { lat: 43.6532, lng: -79.3832 }
            });
            
            const locations = @Html.Raw(JsonSerializer.Serialize(
                                  Model.ItineraryItems.Select(i => new {
                                      lat = i.Location.Latitude,
                                      lng = i.Location.Longitude
                                  })
                              ));
            
            locations.forEach(loc => {
                new google.maps.Marker({
                    position: loc,
                    map: map
                });
            });

            let selectedPlace = null;
            const searchInput = document.getElementById('attractionSearch');
            const btnAdd = document.getElementById('btnAddAttraction');

            // Initialize Google Places Autocomplete
            const autocomplete = new google.maps.places.Autocomplete(searchInput, {
                fields: ['place_id', 'name', 'formatted_address', 'geometry']
            });

            // When a place is selected from the dropdown
            autocomplete.addListener('place_changed', () => {
                const place = autocomplete.getPlace();
                if (!place.geometry) return;

                selectedPlace = {
                    placeId: place.place_id,
                    name: place.name,
                    address: place.formatted_address,
                    latitude: place.geometry.location.lat(),
                    longitude: place.geometry.location.lng()
                };

                btnAdd.disabled = false;
            });

            btnAdd.addEventListener('click', async () => {
                if (!selectedPlace) return;

                await fetch('/Itinerary/AddAttraction', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        itineraryId: @Model.Id,
                        placeId: selectedPlace.placeId,
                        name: selectedPlace.name,
                        address: selectedPlace.address,
                        latitude: selectedPlace.latitude,
                        longitude: selectedPlace.longitude
                    })
                });

                location.reload();
            });
        }
    </script>
    
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyB-5werSTqBxXCNPkyI398eQyVgm3svpEg&libraries=places&v=weekly&callback=initMap" 
            async defer></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.btn-remove').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const card = btn.closest('.attraction-card');
                    const itineraryItemId = card.dataset.itemId;

                    await fetch('/Itinerary/RemoveAttraction', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ itineraryItemId: parseInt(itineraryItemId) })
                    });

                    location.reload();
                });
            });
        });
