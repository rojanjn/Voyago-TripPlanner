@model Itinerary

@{
    ViewBag.Title = "Delete Itinerary";
    Layout = "_Layout";
}

@section Scripts {
    <script>
        // Make navbar white immediately on Details page
        document.querySelector('.navbar').classList.add('scrolled');
    </script>
}

<div class="itinerary-page">
    <div class="itinerary-page-inner">

        <div class="delete-card">
            <h2 class="delete-title">Delete Itinerary</h2>
            <p class="delete-warning">Are you sure you want to delete this itinerary? This cannot be undone.</p>

            <div class="delete-details">
                <div class="delete-row">
                    <span class="delete-label">Title</span>
                    <span class="delete-value">@Model.Title</span>
                </div>
                @if (Model.Country != null)
                {
                    <div class="delete-row">
                        <span class="delete-label">Country</span>
                        <span class="delete-value">@Model.Country.CountryName</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="delete-row">
                        <span class="delete-label">Description</span>
                        <span class="delete-value">@Model.Description</span>
                    </div>
                }
                <div class="delete-row">
                    <span class="delete-label">Dates</span>
                    <span class="delete-value">@Model.StartDate.ToShortDateString() ? @Model.EndDate.ToShortDateString()</span>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="delete-actions">
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.Id)
                <input type="submit" value="Yes, Delete" class="btn-delete-confirm" />
                <a asp-action="Index" class="btn-cancel-white">Cancel</a>
            </form>
        </div>

    </div>
</div>