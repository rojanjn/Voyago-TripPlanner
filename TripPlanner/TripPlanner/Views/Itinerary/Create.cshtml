@model TripPlanner.ViewModels.CreateItineraryViewModel

@{
    Layout = "_Layout";
}

<!DOCTYPE html>

<h2 class="page-title">Plan Your Trip</h2>

<form asp-action="Create" method="post">
    <div class="trip-container">
        <div class="filter-bar">
            <input asp-for="Itinerary.Title" placeholder="Trip Title" />
            <input asp-for="Itinerary.StartDate" placeholder="Start Date" />
            <input asp-for="Itinerary.EndDate" placeholder="End Date" />
  
            <input asp-for="Itinerary.Description" placeholder="Budget" />
        
            <button type="submit" class="btn-create">Create Itinerary</button>
            <button class="btn-nav">Nav</button>
        </div>
        
    </div>
</form>