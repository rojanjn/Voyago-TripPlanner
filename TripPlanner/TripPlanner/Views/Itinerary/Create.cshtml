@model TripPlanner.Models.Itinerary

@{
    Layout = "_Layout";
}

<!-- This script makes sure start-date is not before end-date -->
@section Scripts {
    <script>
        // Make navbar white immediately on Details page
        document.querySelector('.navbar').classList.add('scrolled');
    </script>


    <script>
        // Date validation
        const startDate = document.querySelector('input[name="StartDate"]');
        const endDate = document.querySelector('input[name="EndDate"]');

        if (startDate && endDate) {
            endDate.addEventListener('change', function() {
                if (startDate.value && endDate.value) {
                    if (new Date(endDate.value) < new Date(startDate.value)) {
                        alert('End date cannot be before start date');
                        endDate.value = '';
                    }
                }
            });

            startDate.addEventListener('change', function() {
                if (startDate.value && endDate.value) {
                    if (new Date(endDate.value) < new Date(startDate.value)) {
                        alert('End date cannot be before start date');
                        endDate.value = '';
                    }
                }
            });
        }
    </script>

    <!-- Validation logic for required fields -->
	<partial name="_ValidationScriptsPartial" />
}

<div class="itinerary-page">
    <div class="itinerary-page-inner">
        <h2 class="form-card-title" style="color: white; text-align: center; margin-bottom: 1rem;">Plan Your Trip</h2>

        <form asp-action="Create" method="post">
            
            @* Client side validation *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-card">
                <div class="form-field">
                    <input asp-for="Title" class="form-input" placeholder="Trip Title"/>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label class="form-label">Where are you going?</label>
                    <select asp-for="CountryId" class="form-input">
                        <option value="">Select a Destination...</option>
                        @foreach (var country in ViewBag.Countries)
                        {
                            <option value="@country.CountryId">@country.CountryName</option>
                        }
                    </select>
                </div>

                <div class="form-field">
                    <input asp-for="Description" class="form-input" placeholder="Description or Note?"/>
                </div>

                <div class="form-field">
                    <label class="form-label">Add Dates</label>
                    <div class="dates-row">
                        <input asp-for="StartDate" class="form-input" type="date"/>
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                        
                        <input asp-for="EndDate" class="form-input" type="date"/>
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">Create Trip</button>
                    <a asp-action="Index" class="btn-cancel-white">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>