@model Itinerary

@{
    Layout = "_Layout";
}

<!DOCTYPE html>

<h2 class="page-title">Plan Your Trip</h2>

<form asp-action="Create" method="post">
    <div class="trip-container">
        <div class="filter-bar">
            <input asp-for="Title" placeholder="Trip Title" />
            <input asp-for="StartDate" placeholder="Start Date" />
            <input asp-for="EndDate" placeholder="End Date" />
  
            <input asp-for="Description" placeholder="Budget" />
        
            <button type="submit" class="btn-create">Create Itinerary</button>
            <button class="btn-nav">Nav</button>
        </div>

        <div class="content-panels">
            <div class="map-panel">
                <div id="map">Map</div>
            </div>
            <div class="items-panel">
                <div class="items-list">Items</div>
            </div>
        </div>
    </div>
</form>