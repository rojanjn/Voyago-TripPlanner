@model TripPlanner.Dtos.Itinerary.SaveItineraryDto

@{
    ViewData["Title"] = "Edit Itinerary";
}

@section Scripts {
    <script>
        // Make navbar white immediately on Details page
        document.querySelector('.navbar').classList.add('scrolled');
    </script>

    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}

<div class="itinerary-page">
    <div class="itinerary-page-inner">

        <div class="form-card">
            <h2 class="form-card-title">Edit Your Trip</h2>

            <form asp-action="Edit" method="post">
                <input type="hidden" name="id" value="@ViewBag.ItineraryId" />

                <!-- Add validation summary -->
                <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 1rem;"></div>

                <div class="form-field">
                    <label class="form-label">Trip Title</label>
                    <input asp-for="Title" class="form-input" placeholder="Trip Title" maxlength="60" />
                </div>

                <div class="form-field">
                    <label class="form-label">Where are you going?</label>
                    <select asp-for="CountryId" class="form-input">
                        <option value="">Select a Destination...</option>
                        @foreach (var country in ViewBag.Countries)
                        {
                            <option value="@country.CountryId">@country.CountryName</option>
                        }
                    </select>
                </div>

                <div class="form-field">
                    <label class="form-label">Description <span class="optional">(Optional)</span></label>
                    <input asp-for="Description" class="form-input" placeholder="Description" />
                </div>

                <div class="form-field">
                    <label class="form-label">Dates <span class="optional">(Optional)</span></label>
                    <div class="dates-row">
                        <input asp-for="StartDate" class="form-input date-input" />
                        <input asp-for="EndDate" class="form-input date-input" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">Save Changes</button>
                    <a asp-action="Index" class="btn-cancel-white">Cancel</a>
                </div>
            </form>
        </div>

    </div>
</div>