        <div class="feature-row">
            <div class="feature-row-img">
                <div class="feature-img-placeholder"><img src="~/img/travel.jpg" alt="Travels" /></div>
            </div>
            <div class="feature-row-text">
                <h3>Travel Smarter</h3>
                <p>Keep all your trip details organized and accessible — wherever your journey takes you.</p>
            </div>
        </div>

