@{
    ViewData["Title"] = "Home Page";
    ViewData["BodyClass"] = "homepage";
}

<!-- Hero Section -->
<div class="hero">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="hero-brand">Voyago</div>
            <h1 class="hero-title">Plan unforgettable<br />trips, your way.</h1>
            <p class="hero-subtitle">Build detailed itineraries, discover attractions, and travel smarter with Voyago.</p>
            <a asp-controller="Itinerary" asp-action="Index" class="hero-cta">Start Planning →</a>
        </div>
        <div class="hero-image-wrap">
            <img src="~/img/banner.png" alt="Travel" class="hero-img" />
        </div>
    </div>

    <!-- Decorative shapes -->
    <div class="shape shape-ring"></div>
    <div class="shape shape-dot-1"></div>
    <div class="shape shape-dot-2"></div>
    <div class="shape shape-dot-3"></div>
</div>

<!-- Features Section -->
<section class="features-section">
    <div class="container">
        <h2 class="section-title">✦ Everything you need to travel better ✦</h2>
        <p class="section-subtitle">From planning to exploring, Voyago has you covered.</p>

        <!-- Feature 1 -->
        <div class="feature-row">
            <div class="feature-row-img">
                <div class="feature-img-placeholder"><img src="~/img/itineraries.jpg" alt="Tourist Guide Signs" /></div>
            </div>
            <div class="feature-row-text">
                <h3>Build Itineraries</h3>
                <p>Create detailed day-by-day travel plans with destinations, activities, and personal notes — all in one organized place.</p>
            </div>
        </div>

