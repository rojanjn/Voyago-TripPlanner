# ==========================================
# 1. Sensitive Information & Local Settings
# ==========================================
# Prevent leaking database connection strings or secrets
/TripPlanner/TripPlanner/appsettings.json
/TripPlanner/TripPlanner/appsettings.Development.json
.env
*.db
*.log
wwwroot/logs/*.txt

# ==========================================
# 2. IDE Internal Files (Prevents Sync Conflicts)
# ==========================================
# JetBrains Rider / IntelliJ / VS Code settings
.idea/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user
riderModule.iml
_ReSharper*/
/_ReSharper.Caches/

# ==========================================
# 3. Build Outputs & Compiled Files
# ==========================================
bin/
obj/
out/
*.exe
*.dll
*.pdb
*.cache
packages/
node_modules/

# ==========================================
# 4. Auto-generated Code (Regenerated by IDE)
# ==========================================
*.g.cs
*.g.i.cs
*.generated.cs
*.Designer.cs
*.AssemblyInfo.cs

# ==========================================
# 5. Deployment & Publishing
# ==========================================
*.Publish.xml
*.pubxml
*.pubxml.user

# ==========================================
# 6. OS Specific Files
# ==========================================
*.DS_Store
.editorconfig
/TripPlanner/TripPlanner/appsettings.json
